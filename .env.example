# === Easy Mode (zero credentials) ===
# RPC + LLM + remote GPU grind all auto-pay with USDC from your wallet.
PRIVATE_KEY=
USE_X402=true
USE_X402_GRIND=true
ALLOW_LOCAL_FALLBACK_WITH_X402=false

# === Custom Configuration (override any defaults below) ===

# RPC — bring your own endpoint instead of x402
# RPC_URL=https://base-mainnet.g.alchemy.com/v2/YOUR_KEY
# USE_X402=false

# LLM Provider (clawrouter / openai / anthropic / gemini / ollama / claude-code / codex)
# Default: clawrouter when USE_X402=true, openai otherwise
# LLM_PROVIDER=clawrouter
# LLM_MODEL=blockrun/eco
# CLAWROUTER_PORT=8402    # only if default port is in use

# API key (not needed for clawrouter, ollama, claude-code, or codex)
# LLM_API_KEY=

# Provider-specific keys (alternative to LLM_API_KEY)
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GEMINI_API_KEY=

# Ollama (only if LLM_PROVIDER=ollama)
# OLLAMA_URL=http://127.0.0.1:11434

# Bridging (only needed for `apow fund`)
# SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
# ETHEREUM_RPC_URL=https://cloudflare-eth.com
# SQUID_INTEGRATOR_ID=

# x402 GPU Grinding (remote RTX 4090, zero setup)
# Enabled automatically in Easy Mode. Advanced Mode can disable or run a hybrid fallback.
# USE_X402_GRIND=true
# ALLOW_LOCAL_FALLBACK_WITH_X402=true
# GRIND_URL=https://grind.apow.io/grind

# GPU Mining (optional — auto-detected, massive speed boost)
# Run `apow build-grinders` to compile native binaries automatically.
# GRINDER_MODE=auto                       # auto (default) or js (force JS-only)
# GPU_GRINDER_PATH=./gpu/grinder-gpu      # Metal binary (macOS, auto-detected)
# CUDA_GRINDER_PATH=~/.apow/grinder-cuda  # CUDA binary (NVIDIA GPU, auto-detected)
# CPU_GRINDER_PATH=./gpu/grinder-cpu      # C binary (any platform, auto-detected)
# CPU_THREADS=16                          # Threads for CPU-C grinder (default: all cores)
# Remote GPU via Vast.ai (see: local/vast-setup.sh)
# VAST_IP=                                # Remote GPU host IP
# VAST_PORT=                              # Remote GPU SSH port
# REMOTE_GRINDER=/root/grinder-cuda       # Path to CUDA binary on remote

# Contract addresses (defaults built-in, override only if needed)
# MINING_AGENT_ADDRESS=0xB7caD3ca5F2BD8aEC2Eb67d6E8D448099B3bC03D
# AGENT_COIN_ADDRESS=0x12577CF0D8a07363224D6909c54C056A183e13b3
