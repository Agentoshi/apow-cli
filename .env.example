# Wallet
PRIVATE_KEY=

# RPC — You need one of these two options:
# Option 1: Bring your own RPC URL (free from Alchemy, QuickNode, etc.)
RPC_URL=
# Option 2: Auto-pay via QuickNode x402 ($10 USDC for ~1M calls, no API key needed)
# USE_X402=true

# LLM Provider (openai / anthropic / gemini / ollama / claude-code / codex)
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini

# API key (not needed for ollama, claude-code, or codex)
LLM_API_KEY=

# Provider-specific keys (alternative to LLM_API_KEY)
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GEMINI_API_KEY=

# Ollama (only if LLM_PROVIDER=ollama)
# OLLAMA_URL=http://127.0.0.1:11434

# Bridging (only needed for `apow fund`)
# SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
# SQUID_INTEGRATOR_ID=

# Contract addresses (defaults built-in, override only if needed)
# MINING_AGENT_ADDRESS=0xB7caD3ca5F2BD8aEC2Eb67d6E8D448099B3bC03D
# AGENT_COIN_ADDRESS=0x12577CF0D8a07363224D6909c54C056A183e13b3
