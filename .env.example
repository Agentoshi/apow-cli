# Wallet
PRIVATE_KEY=

# RPC
RPC_URL=https://mainnet.base.org

# LLM Provider (openai / anthropic / gemini / ollama / claude-code / codex)
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini

# API key (not needed for ollama, claude-code, or codex)
LLM_API_KEY=

# Provider-specific keys (alternative to LLM_API_KEY)
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GEMINI_API_KEY=

# Ollama (only if LLM_PROVIDER=ollama)
# OLLAMA_URL=http://127.0.0.1:11434

# Contract addresses (set after deployment)
MINING_AGENT_ADDRESS=
AGENT_COIN_ADDRESS=
